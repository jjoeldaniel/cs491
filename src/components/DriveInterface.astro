---
import { OrganizationSwitcher } from "@clerk/astro/components";
---

<div class="flex h-[calc(100vh-73px)] w-full overflow-hidden">
  <aside
    class="w-48 md:w-64 p-4 hidden sm:flex flex-col gap-6 border-r bg-gray-50/50"
  >
    <div class="w-full">
      <p
        class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2"
      >
        Workspace
      </p>
      <OrganizationSwitcher
        hidePersonal={false}
        appearance={{
          elements: {
            organizationSwitcherTrigger:
              "w-full justify-start border border-gray-200 bg-white shadow-sm",
          },
        }}
      />
    </div>

    <div>
      <button
        id="new-btn"
        class="flex items-center gap-2 bg-blue-600 hover:bg-blue-700 shadow-sm rounded-lg px-4 py-2.5 transition-all text-sm font-medium text-white w-full"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg
        >
        Upload File
      </button>
      <input type="file" id="file-input" class="hidden" multiple />
    </div>
  </aside>

  <main
    id="drive-main"
    class="flex-1 relative p-6 overflow-y-auto bg-white transition-colors"
  >
    <div
      id="drag-overlay"
      class="absolute inset-2 rounded-xl border-2 border-blue-400 border-dashed bg-blue-50/90 z-50 flex items-center justify-center hidden pointer-events-none"
    >
      <div class="text-center">
        <p class="text-2xl font-semibold text-blue-700">
          Drop files to instantly upload
        </p>
      </div>
    </div>

    <div class="flex justify-between items-end mb-6 border-b pb-2">
      <h2 id="workspace-title" class="text-lg font-medium text-gray-800">
        My Drive
      </h2>
      <span id="upload-status" class="text-sm font-medium text-blue-600 hidden"
        >Uploading...</span
      >
    </div>

    <div
      id="file-list-container"
      class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-4"
    >
      <p class="text-gray-500 col-span-full" id="loading-text">
        Loading workspace...
      </p>
    </div>
  </main>
</div>

<script>
  import { getSupabaseClient } from "../lib/supabase";

  const container = document.getElementById("file-list-container");
  const driveMain = document.getElementById("drive-main");
  const dragOverlay = document.getElementById("drag-overlay");
  const newBtn = document.getElementById("new-btn");
  const fileInput = document.getElementById("file-input");
  const uploadStatus = document.getElementById("upload-status");
  const workspaceTitle = document.getElementById("workspace-title");

  // Utility to get the current active workspace ID (either Org ID or User ID)
  function getActiveWorkspaceId() {
    return window.Clerk.organization?.id || window.Clerk.user.id;
  }

  // Utility to get the workspace name for the UI
  function updateWorkspaceTitle() {
    workspaceTitle.textContent =
      window.Clerk.organization?.name || "Personal Drive";
  }

  const waitForClerk = setInterval(() => {
    if (window.Clerk && window.Clerk.loaded) {
      clearInterval(waitForClerk);
      if (window.Clerk.user) {
        updateWorkspaceTitle();
        loadFiles();

        // Listen for organization changes in the Clerk UI
        window.Clerk.addListener(({ organization }) => {
          updateWorkspaceTitle();
          loadFiles();
        });
      } else {
        container.innerHTML =
          '<p class="text-gray-500 col-span-full">Please sign in.</p>';
      }
    }
  }, 100);

  // --- Drag and Drop Logic ---
  let dragCounter = 0;
  driveMain.addEventListener("dragenter", (e) => {
    e.preventDefault();
    dragCounter++;
    dragOverlay.classList.remove("hidden");
  });
  driveMain.addEventListener("dragleave", (e) => {
    e.preventDefault();
    dragCounter--;
    if (dragCounter === 0) dragOverlay.classList.add("hidden");
  });
  driveMain.addEventListener("dragover", (e) => e.preventDefault());
  driveMain.addEventListener("drop", (e) => {
    e.preventDefault();
    dragCounter = 0;
    dragOverlay.classList.add("hidden");
    handleUpload(e.dataTransfer.files);
  });

  newBtn.addEventListener("click", () => fileInput.click());
  fileInput.addEventListener("change", (e) => handleUpload(e.target.files));

  // --- Core Functions ---
  async function handleUpload(files) {
    if (!files || files.length === 0 || !window.Clerk?.user) return;
    const workspaceId = getActiveWorkspaceId();
    const supabase = await getSupabaseClient();

    uploadStatus.classList.remove("hidden");
    uploadStatus.textContent = `Uploading ${files.length} file(s)...`;

    for (const file of files) {
      const filePath = `${workspaceId}/${Date.now()}_${file.name}`;
      const { error } = await supabase.storage
        .from("user_files")
        .upload(filePath, file);
      if (error) console.error("Upload Error:", error);
    }

    uploadStatus.textContent = "Upload complete!";
    setTimeout(() => uploadStatus.classList.add("hidden"), 3000);
    loadFiles();
  }

  async function loadFiles() {
    const workspaceId = getActiveWorkspaceId();
    const supabase = await getSupabaseClient();

    container.innerHTML =
      '<p class="text-gray-500 col-span-full">Loading...</p>';

    const { data, error } = await supabase.storage
      .from("user_files")
      .list(workspaceId, {
        limit: 100,
        sortBy: { column: "created_at", order: "desc" },
      });

    if (error) {
      container.innerHTML =
        '<p class="text-red-500 col-span-full">Failed to load workspace files.</p>';
      return;
    }

    const validFiles =
      data?.filter((f) => f.name !== ".emptyFolderPlaceholder") || [];

    if (validFiles.length === 0) {
      container.innerHTML =
        '<div class="col-span-full py-20 text-center text-gray-400">This workspace is empty.</div>';
      return;
    }

    container.innerHTML = "";

    validFiles.forEach((file) => {
      const cleanFileName = file.name.replace(/^\d+_/, "");
      const fullPath = `${workspaceId}/${file.name}`;

      const fileCard = document.createElement("div");
      fileCard.className =
        "group flex flex-col justify-between p-3 rounded-xl border border-gray-200 bg-gray-50/50 hover:bg-blue-50 transition-colors";

      const previewArea = document.createElement("div");
      previewArea.className = "cursor-pointer mb-3";
      previewArea.onclick = () => previewFile(fullPath);

      const iconWrapper = document.createElement("div");
      iconWrapper.className =
        "flex items-center justify-center h-16 mb-2 text-gray-400 group-hover:text-blue-500";
      iconWrapper.innerHTML = `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>`;

      const fileNameDisplay = document.createElement("span");
      fileNameDisplay.className =
        "block text-sm font-medium text-gray-700 truncate text-center";
      fileNameDisplay.textContent = cleanFileName;

      previewArea.appendChild(iconWrapper);
      previewArea.appendChild(fileNameDisplay);

      const actions = document.createElement("div");
      actions.className =
        "flex justify-between items-center border-t border-gray-200 pt-2 mt-auto";

      const renameBtn = document.createElement("button");
      renameBtn.className =
        "text-xs font-medium text-gray-500 hover:text-blue-600";
      renameBtn.textContent = "Rename";
      renameBtn.onclick = () => renameFile(fullPath, cleanFileName);

      const deleteBtn = document.createElement("button");
      deleteBtn.className =
        "text-xs font-medium text-gray-500 hover:text-red-600";
      deleteBtn.textContent = "Delete";
      deleteBtn.onclick = () => deleteFile(fullPath);

      actions.appendChild(renameBtn);
      actions.appendChild(deleteBtn);

      fileCard.appendChild(previewArea);
      fileCard.appendChild(actions);
      container.appendChild(fileCard);
    });
  }

  async function previewFile(path) {
    const supabase = await getSupabaseClient();
    const { data, error } = await supabase.storage
      .from("user_files")
      .createSignedUrl(path, 60);
    if (!error) window.open(data.signedUrl, "_blank");
  }

  async function deleteFile(path) {
    if (!confirm("Delete this file?")) return;
    const supabase = await getSupabaseClient();
    await supabase.storage.from("user_files").remove([path]);
    loadFiles();
  }

  async function renameFile(oldPath, oldName) {
    const newName = prompt("New file name:", oldName);
    if (!newName || newName === oldName) return;
    const workspaceId = getActiveWorkspaceId();
    const newPath = `${workspaceId}/${Date.now()}_${newName}`;
    const supabase = await getSupabaseClient();
    await supabase.storage.from("user_files").move(oldPath, newPath);
    loadFiles();
  }
</script>
